## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is a combination of the VisualStudio, DotNetCore and 
## Windows gitignore templates from GitHub.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework Core of VS2017+
*.Migrations.cs

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.Development.json
appsettings.Local.json

# Visual Studio Code
.vscode/

# Rider
.idea/

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
